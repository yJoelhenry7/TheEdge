# Copy this file to `.env.local` in the project root, then fill in your values.
# Restart `npm run dev` after saving.

# ── Where applications are delivered ─────────────────────────────────────────
CAREERS_TO_EMAIL=talent@vvrindustries.com

# Optional: send a short confirmation to the applicant (true / false)
CAREERS_SEND_CONFIRMATION=false

# ── SMTP (GoDaddy Titan — recommended if you use Titan Email) ────────────────
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=talent@vvrindustries.com
SMTP_PASS=your-mailbox-password
SMTP_FROM=talent@vvrindustries.com

# ── Alternative: GoDaddy Workspace (Microsoft 365 / legacy GoDaddy mail) ─────
# SMTP_HOST=smtpout.secureserver.net
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=talent@vvrindustries.com
# SMTP_PASS=your-mailbox-password
# SMTP_FROM=talent@vvrindustries.com
